                JOptionPane.showMessageDialog(null, "Bienvenido administrador.");
                jtxtUsuario.setText("");
                jtxtContra.setText("");
           
                Admin ver = new Admin();
                ver.setVisible(true);
                this.dispose();
                break;
            }else if(Datos.USEROP[i].equals(usuario) && Datos.CONTRAOP[i].equals(contra)){
                JOptionPane.showMessageDialog(null, "Bienvenido operador.");
                jtxtUsuario.setText("");
                jtxtContra.setText("");
           
                Operador ver = new Operador();
