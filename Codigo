    private void jbtnAgregarActionPerformed(java.awt.event.ActionEvent evt) {                                            
    String nombre = JOptionPane.showInputDialog(null, "Ingresa los nombres del operador");
    String apellido = JOptionPane.showInputDialog(null, "Ingresa los apellidos del operador");
    String dpi = JOptionPane.showInputDialog(null, "Ingresa el DPI del operador");
    String user = JOptionPane.showInputDialog(null, "Ingresa el usuario del operador");
    String contra = JOptionPane.showInputDialog(null, "Ingresa la contraseña del operador");
    
    Datos.NOMBRE[Datos.i]=nombre;
    Datos.APELLIDO[Datos.i]=apellido;
    Datos.DPI[Datos.i]=dpi;
    Datos.USEROP[Datos.i]=user;
    Datos.CONTRAOP[Datos.i]=contra;
    
    if(nombre.isEmpty() || apellido.isEmpty() || dpi.isEmpty() || user.isEmpty() || contra.isEmpty()){
        JOptionPane.showMessageDialog(null, "No pueden haber campos vacios", "ERROR", JOptionPane.WARNING_MESSAGE);
        Datos.NOMBRE[Datos.i]=null;
        Datos.APELLIDO[Datos.i]=null;
        Datos.DPI[Datos.i]=null;
        Datos.USEROP[Datos.i]=null;
        Datos.CONTRAOP[Datos.i]=null;
    }else{
        JOptionPane.showMessageDialog(null, "Se guardo coorectamente");
    }
    Datos.i++;
    }                                           

    private void jbtnMostrarActionPerformed(java.awt.event.ActionEvent evt) {                                            
    Datos.limpiar(jtbPantalla);
    
    DefaultTableModel agregar = new DefaultTableModel();
    agregar.addColumn("Nombres");
    agregar.addColumn("Apellidos");
    agregar.addColumn("DPI");
    agregar.addColumn("Usuario");
    agregar.addColumn("Contraseña");
    
    jtbPantalla.setModel(agregar);
    //Mostrar los datos
    for(int i=0; i<Datos.i; i++){
        agregar.addRow(new Object[]{Datos.NOMBRE[i], Datos.APELLIDO[i], Datos.DPI[i], Datos.USEROP[i], Datos.CONTRAOP[i]});
    }
      
    }                                           

