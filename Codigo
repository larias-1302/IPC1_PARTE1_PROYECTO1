                this.dispose(); 
                break;
            }else{
                JOptionPane.showMessageDialog(null, "Usuario o contraseña inexistentes", "ERROR AL INICIAR SESION", JOptionPane.WARNING_MESSAGE);
                jtxtUsuario.setText("");
                jtxtContra.setText("");
                break;
            }
        }
        
