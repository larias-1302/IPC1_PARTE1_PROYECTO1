import javax.swing.JTable;
import javax.swing.table.DefaultTableModel;
public class Datos {
    public static int i=0;
    public static String[] NOMBRE = new String[100];
    public static String[] APELLIDO = new String[100];
    public static String[] DPI = new String[100];
    public static String[] USEROP = new String[100];
    public static String[] CONTRAOP = new String[100];

    public static void limpiar(JTable tabla){
        DefaultTableModel limpiar = (DefaultTableModel) tabla.getModel();
        limpiar.setRowCount(0);
    }
}
